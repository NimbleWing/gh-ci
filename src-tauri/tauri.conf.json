{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "gh-ci",
  "version": "0.1.0",
  "identifier": "com.nimblewing.gh-ci",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "gh-ci",
        "width": 800,
        "height": 600
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis", "msi"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "createUpdaterArtifacts": true
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDQyOTE2ODk3MEM4RThFMEQKUldRTmpvNE1sMmlSUXNscUdCbytLYlBHSUVua0dsanI5d0VuMFVmZTZYT3hrNXFFeXg4VDBWcXYK",
      "endpoints": [
        "https://github.com/NimbleWing/gh-ci/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
